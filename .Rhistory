server <- function(input, output, session) {
# Carga y procesa la base de datos reactivamente
data <- reactive({
req(input$uploadFile) # Asegura que se haya subido un archivo
df <- switch(input$fileType,
".csv" = {
read_csv(input$uploadFile$datapath, locale = locale(encoding = "latin1"))
},
".xlsx" = {
read_excel(input$uploadFile$datapath)
})
return(df)
})
# Renderiza la tabla en el visor
output$dataTable <- renderTable({
data()
})
}
library(shiny)
library(shinyFiles)
library(shiny)
library(readr)
library(readxl)
ui <- fluidPage(
titlePanel("Cargar Base de Datos"),
sidebarLayout(
sidebarPanel(
# 1. Selector del tipo de archivo
radioButtons("fileType", "Seleccionar tipo de archivo:",
choices = c(".csv", ".xlsx"),
selected = ".csv"),
# 2. BotÃ³n para subir archivo
fileInput("uploadFile", "Subir archivo de datos",
accept = c(".csv", ".xlsx")),
tags$hr(),
helpText("Nota: Se admiten archivos .csv y .xlsx.")
),
mainPanel(
# 3. Visor para la base de datos
h3("VisualizaciÃ³n de la Base de Datos"),
tableOutput("dataTable")
)
)
)

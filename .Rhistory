# Carga y procesa la base de datos reactivamente
data <- reactive({
req(input$uploadFile) # Asegura que se haya subido un archivo
df <- switch(input$fileType,
".csv" = {
read_csv(input$uploadFile$datapath, locale = locale(encoding = "latin1"))
},
".xlsx" = {
read_excel(input$uploadFile$datapath)
})
return(df)
})
# Renderiza la tabla en el visor
output$dataTable <- renderTable({
